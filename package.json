{
  "name": "kte-jegyportal",
  "version": "0.1.0",
  "private": true,
  "description": "KTE Jegyportál - Kecskeméti TE official ticketing and season pass platform",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "install:all": "npm install && npm install --workspace=apps/backend && npm install --workspace=apps/frontend",
    "start:backend": "npm exec --workspace=apps/backend -- ts-node -r tsconfig-paths/register src/main.ts",
    "start:frontend": "npm run start --workspace=apps/frontend",
    "start:all": "concurrently -n backend,frontend,stripe -c blue,green,yellow \"npm:start:backend\" \"npm:start:frontend\" \"cd C:/Users/User/Downloads/stripe_1.40.9_windows_x86_64 && ./stripe.exe listen --forward-to localhost:3000/api/webhooks/stripe\"",
    "build:backend": "npm run build --workspace=apps/backend",
    "build:frontend": "npm run build --workspace=apps/frontend",
    "build:all": "npm run build:backend && npm run build:frontend",
    "lint:backend": "npm run lint --workspace=apps/backend",
    "lint:frontend": "npm run lint --workspace=apps/frontend",
    "lint:all": "npm run lint:backend && npm run lint:frontend",
    "test:backend": "npm run test --workspace=apps/backend",
    "test:frontend": "npm run test --workspace=apps/frontend",
    "test:all": "npm run test:backend && npm run test:frontend",
    "migration:run": "npm run migration:run --workspace=apps/backend",
    "migration:revert": "npm run migration:revert --workspace=apps/backend",
    "seed": "npm run seed --workspace=apps/backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.10.0",
    "npm": ">=10.0.0"
  },
  "license": "UNLICENSED"
}
