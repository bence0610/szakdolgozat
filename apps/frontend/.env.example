# =====================================================
# KTE Jegyportál Frontend - Environment configuration
# =====================================================
# Angular nem olvassa közvetlenül a .env fájlokat;
# ezek a változók az `src/environments/environment*.ts`
# generálásához használhatók (pl. CI vagy build script).
# =====================================================

# API base URL — a backend NestJS app
NG_APP_API_URL=http://localhost:3000/api

# Stripe publishable key (frontend Elements integráció)
NG_APP_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Anthropic-hez NEM kell kulcs a frontenden — minden hívás
# a backenden keresztül megy.

# OpenWeatherMap city slug (csak kijelzéshez)
NG_APP_WEATHER_CITY=Kecskemet,HU
