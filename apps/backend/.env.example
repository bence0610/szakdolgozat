# =====================================================
# KTE Jegyportál Backend - Environment configuration
# =====================================================
# Copy this file to .env and fill in real values.
# NEVER commit the actual .env file.
# =====================================================

# --- Application ---
NODE_ENV=development
PORT=3000
APP_NAME=KTE Jegyportal API
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:4200
CORS_ORIGINS=http://localhost:4200

# --- MySQL Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=kte_user
DB_PASSWORD=changeme
DB_DATABASE=kte_jegyportal
DB_SYNCHRONIZE=false
DB_LOGGING=false

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=kte:

# --- Seat Locking ---
SEAT_LOCK_TTL_SECONDS=300

# --- JWT ---
JWT_ACCESS_SECRET=replace-with-strong-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-different-strong-random-secret
JWT_REFRESH_EXPIRES_IN=7d

# --- Bcrypt ---
BCRYPT_ROUNDS=12

# --- Stripe (server-side only!) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CURRENCY=huf

# --- Anthropic Claude API ---
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=1024

# --- OpenWeatherMap ---
OPENWEATHER_API_KEY=
OPENWEATHER_CITY=Kecskemet,HU

# --- Mail (SMTP) ---
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=no-reply@kte.hu
MAIL_PASSWORD=changeme
MAIL_FROM=no-reply@kte.hu

# --- Logging ---
LOG_LEVEL=debug
