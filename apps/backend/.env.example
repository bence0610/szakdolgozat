# =====================================================
# KTE Jegyportál Backend - Environment configuration
# =====================================================
# Copy this file to .env and fill in real values.
# NEVER commit the actual .env file.
# =====================================================

# --- Application ---
NODE_ENV=development
PORT=3000
APP_NAME=KTE Jegyportal API
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:4200
CORS_ORIGINS=http://localhost:4200
HOME_TEAM_NAME=Kecskeméti TE

# --- MySQL Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=kte_user
DB_PASSWORD=changeme
DB_DATABASE=kte_jegyportal
DB_SYNCHRONIZE=false
DB_LOGGING=false

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=kte:

# --- Seat Locking ---
SEAT_LOCK_TTL_SECONDS=300

# --- JWT ---
JWT_ACCESS_SECRET=replace-with-strong-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-different-strong-random-secret
JWT_REFRESH_EXPIRES_IN=7d

# --- Bcrypt ---
BCRYPT_ROUNDS=12

# --- Stripe (server-side only!) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CURRENCY=huf

# --- Anthropic Claude API ---
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=1024

# --- OpenWeatherMap ---
OPENWEATHER_API_KEY=
OPENWEATHER_CITY=Kecskemet,HU
OPENWEATHER_CACHE_TTL_SECONDS=3600

# --- Mail (SMTP) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@kte.hu
SMTP_PASS=changeme
SMTP_FROM=no-reply@kte.hu
EMAIL_RETRY_DELAY_MS=60000
EMAIL_BASE_URL=http://localhost:4200

# --- QR Code Signing ---
QR_SIGNING_SECRET=replace-with-strong-random-qr-secret
QR_TICKET_ISSUER=kte-jegyportal
QR_LOAN_ISSUER=kte-loan

# --- Loyalty ---
LOYALTY_REGISTRATION_POINTS=100
LOYALTY_PROFILE_COMPLETION_POINTS=50
LOYALTY_TICKET_POINTS_PER_TICKET=50
LOYALTY_SEASON_PASS_POINTS=500
LOYALTY_PASS_LOAN_POINTS=25
LOYALTY_CARRYOVER_PERCENT=50

# --- Cron ---
LOAN_RELEASE_CRON=0 * * * *
TICKET_EXPIRE_CRON=0 4 * * *
CRON_TIMEZONE=Europe/Budapest
LOAN_INVITATION_TTL_HOURS=72

# --- Waitlist (Iteration 5) ---
WAITLIST_CLAIM_TTL_SECONDS=600

# --- Chatbot (Iteration 5) ---
CHATBOT_RATE_LIMIT_AUTH=100
CHATBOT_RATE_LIMIT_ANON=20
CHATBOT_HISTORY_TTL_SECONDS=86400
CHATBOT_HISTORY_MAX_MESSAGES=20
CHATBOT_CONTEXT_CACHE_TTL_SECONDS=300

# --- Logging ---
LOG_LEVEL=debug
