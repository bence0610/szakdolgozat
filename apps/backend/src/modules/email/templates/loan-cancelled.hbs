<!DOCTYPE html>
<html lang="hu">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>KTE bérlet kölcsönzés visszavonva</title>
  </head>
  <body style="margin:0; padding:0; background-color:#0F0F0F; color:#F5F5F5; font-family: 'Helvetica Neue', Arial, sans-serif;">
    <table width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr>
        <td align="center" style="padding:24px 12px;">
          <table width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px; width:100%; background-color:#1A1A1A; border:1px solid #2E2E2E; border-radius:12px;">
            <tr>
              <td style="background-color:#2E2E2E; padding:24px 32px;">
                <h1 style="margin:0; font-size:22px; color:#FFFFFF; font-weight:700;">Bérlet kölcsönzés visszavonva</h1>
              </td>
            </tr>
            <tr>
              <td style="padding:32px;">
                <p style="margin:0 0 16px; font-size:16px; line-height:24px;">Szia <strong>{{recipientName}}</strong>,</p>

                {{#if isLender}}
                  <p style="margin:0 0 16px; font-size:16px; line-height:24px;">A(z) <strong>{{matchTitle}}</strong> ({{matchKickoffLabel}}) mérkőzésre létrehozott bérletkölcsön sikeresen visszavonva.</p>
                {{else}}
                  <p style="margin:0 0 16px; font-size:16px; line-height:24px;">A(z) <strong>{{matchTitle}}</strong> ({{matchKickoffLabel}}) mérkőzésre szóló bérletkölcsönt a tulajdonos visszavonta. A korábban kapott QR kód érvénytelen.</p>
                {{/if}}

                {{#if reason}}
                  <p style="margin:0 0 16px; font-size:14px; color:#AAAAAA;">Indok: {{reason}}</p>
                {{/if}}
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
